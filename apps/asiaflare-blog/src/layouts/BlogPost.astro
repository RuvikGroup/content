---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, pubDate, updatedDate, author, tags, heroImage } = post.data;
const formattedPubDate = pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
const formattedUpdatedDate = updatedDate?.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout title={title} description={description}>
  <Header slot="header" />
  <article>
    {heroImage && <img src={heroImage} alt={title} style="width:100%;border-radius:8px;margin-bottom:1.5rem;" />}
    <header style="margin-bottom:2rem;">
      <h1 style="font-size:2rem;font-weight:800;line-height:1.2;margin-bottom:0.75rem;">{title}</h1>
      <p style="color:var(--color-muted);font-size:0.875rem;">
        By {author} &middot; <time datetime={pubDate.toISOString()}>{formattedPubDate}</time>
        {updatedDate && <span> &middot; Updated <time datetime={updatedDate.toISOString()}>{formattedUpdatedDate}</time></span>}
      </p>
      {tags.length > 0 && (
        <div style="margin-top:0.75rem;display:flex;flex-wrap:wrap;gap:0.4rem;">
          {tags.map((tag) => (
            <a href={`/tags/${tag}/`} style="font-size:0.8rem;background:#fee2e2;color:#b91c1c;padding:0.2rem 0.6rem;border-radius:9999px;">
              #{tag}
            </a>
          ))}
        </div>
      )}
    </header>
    <div class="prose">
      <slot />
    </div>
  </article>
  <Footer slot="footer" />
</BaseLayout>

<style>
  .prose { line-height: 1.7; font-size: 1.05rem; }
  .prose :global(h2) { font-size: 1.5rem; font-weight: 700; margin: 2rem 0 0.75rem; }
  .prose :global(h3) { font-size: 1.2rem; font-weight: 600; margin: 1.5rem 0 0.5rem; }
  .prose :global(p) { margin-bottom: 1rem; }
  .prose :global(ul), .prose :global(ol) { margin: 0 0 1rem 1.5rem; }
  .prose :global(li) { margin-bottom: 0.25rem; }
  .prose :global(strong) { font-weight: 700; }
  .prose :global(code) { background: #f3f4f6; padding: 0.15rem 0.3rem; border-radius: 3px; font-size: 0.9em; }
  .prose :global(pre) { background: #1e1e2e; color: #cdd6f4; padding: 1rem; border-radius: 8px; overflow-x: auto; margin-bottom: 1rem; }
</style>
