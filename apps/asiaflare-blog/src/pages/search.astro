---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout title="Search" description="Search AsiaFlare Blog posts.">
  <Fragment slot="head">
    <!-- Pagefind search UI — only loaded on this page, assets exist after postbuild -->
    <link rel="stylesheet" href={`${import.meta.env.BASE_URL}/pagefind/pagefind-ui.css`} />
    <script is:inline define:vars={{ pagefindJsUrl: `${import.meta.env.BASE_URL}/pagefind/pagefind-ui.js` }}>
      var s = document.createElement("script");
      s.src = pagefindJsUrl;
      s.onload = function () {
        var el = document.getElementById("search");
        if (el && typeof PagefindUI !== "undefined") {
          new PagefindUI({ element: "#search", showSubResults: true });
        }
      };
      s.onerror = function () {
        var el = document.getElementById("search");
        if (el) el.innerHTML = "<p>Search is temporarily unavailable. Please try again later.</p>";
      };
      document.head.appendChild(s);
    </script>
  </Fragment>

  <Header slot="header" />

  <h1 class="page-title">Search</h1>
  <div id="search" role="search" aria-label="Site search"></div>

  <Footer slot="footer" />
</BaseLayout>

<style>
  .page-title { font-size: 2rem; font-weight: 800; margin-bottom: 1.5rem; }
</style>
