---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout title="Search" description="Search AsiaFlare Blog posts.">
  <Fragment slot="head">
    <!-- Pagefind search UI — only loaded on this page, assets exist after postbuild -->
    <link rel="stylesheet" href={`${import.meta.env.BASE_URL}/pagefind/pagefind-ui.css`} />
    <script is:inline define:vars={{ pagefindJsUrl: `${import.meta.env.BASE_URL}/pagefind/pagefind-ui.js`, baseUrl: import.meta.env.BASE_URL }}>
      var s = document.createElement("script");
      s.src = pagefindJsUrl;
      s.onload = function () {
        var el = document.getElementById("search");
        if (!el || typeof PagefindUI === "undefined") return;
        try {
          new PagefindUI({
            element: "#search",
            showSubResults: true,
            processResult: function (result) {
              if (result.url && result.url.charAt(0) === "/" && result.url.indexOf(baseUrl) !== 0) {
                result.url = baseUrl + result.url;
              }
              return result;
            }
          });
        } catch (e) {
          el.innerHTML = "<p>Search failed to initialize. Please try again later.</p>";
        }
      };
      s.onerror = function () {
        var el = document.getElementById("search");
        if (el) el.innerHTML = "<p>Search is temporarily unavailable. Please try again later.</p>";
      };
      document.head.appendChild(s);
    </script>
  </Fragment>

  <Header slot="header" />

  <h1 class="page-title">Search</h1>
  <div id="search" role="search" aria-label="Site search"></div>

  <Footer slot="footer" />
</BaseLayout>

<style>
  .page-title { font-size: 2rem; font-weight: 800; margin-bottom: 1.5rem; }
</style>
