---
interface Props {
  src: string;
  title?: string;
  height?: number;
  caption?: string;
}

const { src, title = 'Map', height = 400, caption } = Astro.props;
---

<figure class="map-embed">
  <div class="map-frame" style={`height: ${height}px`}>
    <iframe
      src={src}
      title={title}
      loading="lazy"
      allowfullscreen
      referrerpolicy="no-referrer-when-downgrade"
    ></iframe>
  </div>
  {caption && <figcaption class="map-caption">{caption}</figcaption>}
</figure>

<style>
  .map-embed {
    margin: 32px 0;
  }
  .map-frame {
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid var(--color-border);
    background: var(--color-bg);
  }
  .map-frame iframe {
    width: 100%;
    height: 100%;
    border: none;
    display: block;
  }
  .map-caption {
    text-align: center;
    font-size: 13px;
    color: var(--color-muted);
    margin-top: 10px;
    font-style: italic;
  }
</style>
