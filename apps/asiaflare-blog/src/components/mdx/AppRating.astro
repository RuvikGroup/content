---
const VALID_PLATFORMS = ['ios', 'android', 'both'] as const;
type Platform = typeof VALID_PLATFORMS[number];

interface Props {
  rating: number;
  count?: number;
  platform?: Platform;
  appName?: string;
}

const { rating, count, platform = 'both', appName } = Astro.props;

const numericRating = Number(rating);
if (isNaN(numericRating)) {
  throw new Error(
    `AppRating: prop "rating" must be a number, got "${rating}". Use JSX syntax: rating={4.8} not rating="4.8".`
  );
}

if (platform && !VALID_PLATFORMS.includes(platform as Platform)) {
  throw new Error(
    `AppRating: unknown platform "${platform}". Valid values are: ${VALID_PLATFORMS.join(', ')}.`
  );
}

const clampedRating = Math.min(5, Math.max(0, numericRating));
const safePlatform = platform as Platform;
---

<div class="app-rating-card">
  <div class="app-rating-icon">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <rect x="5" y="2" width="14" height="20" rx="2" ry="2"/>
      <line x1="12" y1="18" x2="12.01" y2="18"/>
    </svg>
  </div>
  <div class="app-rating-info">
    {appName && <div class="app-rating-name">{appName}</div>}
    <div class="app-rating-score">
      <span class="app-rating-num">{clampedRating.toFixed(1)}</span>
      <div class="app-rating-stars">
        {Array.from({ length: 5 }, (_, i) => {
          const filled = i < Math.floor(clampedRating);
          const half = !filled && i === Math.floor(clampedRating) && (clampedRating % 1) >= 0.5;
          return (
            <svg class={`astar ${filled ? 'astar--full' : half ? 'astar--half' : 'astar--empty'}`} viewBox="0 0 24 24">
              <polygon
                points="12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26"
                fill={filled || half ? 'currentColor' : 'none'}
                stroke="currentColor"
                stroke-width="1.5"
              />
            </svg>
          );
        })}
      </div>
    </div>
    <div class="app-rating-sub">
      {count && <span>{count.toLocaleString()} ratings</span>}
      {count && safePlatform && <span class="app-rating-dot"></span>}
      {safePlatform === 'ios' && <span>App Store</span>}
      {safePlatform === 'android' && <span>Google Play</span>}
      {safePlatform === 'both' && <span>App Store &amp; Google Play</span>}
    </div>
  </div>
</div>

<style>
  .app-rating-card {
    display: flex;
    align-items: center;
    gap: 20px;
    background: linear-gradient(135deg, rgba(var(--color-primary-rgb, 198,40,40), 0.05), rgba(var(--color-primary-rgb, 198,40,40), 0.02));
    border: 1px solid rgba(var(--color-primary-rgb, 198,40,40), 0.15);
    border-radius: 16px;
    padding: 20px 24px;
    margin: 28px 0;
  }
  .app-rating-icon {
    width: 52px;
    height: 52px;
    border-radius: 14px;
    background: var(--color-primary);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: #fff;
  }
  .app-rating-icon svg { width: 26px; height: 26px; }
  .app-rating-name {
    font-family: var(--font-display, 'Urbanist', sans-serif);
    font-size: 15px;
    font-weight: 800;
    color: var(--color-text);
    margin-bottom: 4px;
  }
  .app-rating-score { display: flex; align-items: center; gap: 10px; margin-bottom: 4px; }
  .app-rating-num {
    font-family: var(--font-display, 'Urbanist', sans-serif);
    font-size: 28px;
    font-weight: 900;
    color: var(--color-text);
    line-height: 1;
    letter-spacing: -0.02em;
  }
  .app-rating-stars { display: flex; gap: 3px; }
  .astar { width: 16px; height: 16px; color: var(--color-primary); }
  .astar--empty { color: #d1d5db; }
  .app-rating-sub {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    color: var(--color-muted);
  }
  .app-rating-dot {
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: #d1d5db;
    flex-shrink: 0;
  }
</style>
