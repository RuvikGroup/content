---
import ThemeToggle from './ThemeToggle.astro';
---

<header>
  <nav>
    <a href={import.meta.env.BASE_URL} class="logo-link" aria-label="AsiaFlare Blog">
      <img src={`${import.meta.env.BASE_URL}/logo-light.svg`} alt="AsiaFlare" height="32" class="logo logo-light" />
      <img src={`${import.meta.env.BASE_URL}/logo-dark.svg`} alt="AsiaFlare" height="32" class="logo logo-dark" />
    </a>
    <div class="nav-right">
      <ul>
        <li><a href={import.meta.env.BASE_URL}>Home</a></li>
        <li><a href={`${import.meta.env.BASE_URL}/tags/`}>Tags</a></li>
        <li><a href={`${import.meta.env.BASE_URL}/search/`}>Search</a></li>
        <li><a href={`${import.meta.env.BASE_URL}/rss.xml`}>RSS</a></li>
      </ul>
      <ThemeToggle />
    </div>
  </nav>
</header>

<style>
  header {
    border-bottom: 1px solid var(--color-border);
    background: var(--color-bg-surface);
    position: sticky;
    top: 0;
    z-index: 10;
    transition: background-color 0.2s ease, border-color 0.2s ease;
  }
  nav {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0.875rem 1rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }
  .logo-link { text-decoration: none; display: flex; align-items: center; flex-shrink: 0; }
  .nav-right { display: flex; align-items: center; gap: 1.5rem; }
  .logo { display: block; }
  .logo-dark { display: none; }
  [data-theme='dark'] .logo-light { display: none; }
  [data-theme='dark'] .logo-dark { display: block; }
  /* Fallback when JS hasn't set data-theme yet (no-JS, CSP) */
  @media (prefers-color-scheme: dark) {
    html:not([data-theme]) .logo-light { display: none; }
    html:not([data-theme]) .logo-dark { display: block; }
  }
  ul {
    list-style: none;
    display: flex;
    gap: 1.5rem;
  }
  ul a {
    color: var(--color-text);
    font-size: 0.9rem;
    font-weight: 500;
  }
  ul a:hover { color: var(--color-primary); }
</style>
