---
import { getCollection, render } from 'astro:content';
import BlogPost from '../layouts/BlogPost.astro';
import Callout from '../components/mdx/Callout.astro';
import MapEmbed from '../components/mdx/MapEmbed.astro';
import ReviewCard from '../components/mdx/ReviewCard.astro';
import RatingBreakdown from '../components/mdx/RatingBreakdown.astro';
import AppRating from '../components/mdx/AppRating.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BlogPost post={post}>
  <Content components={{ Callout, MapEmbed, ReviewCard, RatingBreakdown, AppRating }} />
</BlogPost>
