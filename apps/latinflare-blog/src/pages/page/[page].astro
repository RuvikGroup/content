---
import { getCollection } from 'astro:content';
import type { GetStaticPathsOptions, Page } from 'astro';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import PostCard from '../../components/PostCard.astro';

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  const sorted = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
  const pages = paginate(sorted, { pageSize: 7 });
  return pages.filter(({ params }) => Number(params.page) > 1);
}

interface Props {
  page: Page<CollectionEntry<'blog'>>;
}

const { page } = Astro.props;
const all = await getCollection('blog', ({ data }) => !data.draft);
const trending = all
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 5);

const readingTime = (post: CollectionEntry<'blog'>) =>
  Math.max(1, Math.round((post.body ?? '').split(/\s+/).length / 200));
---

<BaseLayout
  title={`Blog — Page ${page.currentPage}`}
  description="Dating tips, success stories, and guides for Latin singles."
  fullWidth
>
  <Header slot="header" />

  <div class="page-header">
    <div class="page-header-inner">
      <div class="page-header-label">All Posts</div>
      <h1>LatinFlare Blog</h1>
      <p>Page {page.currentPage} of {page.lastPage}</p>
    </div>
  </div>

  <div class="blog-outer">
    <div class="blog-body">
      <div class="blog-cards">
        {page.data.map((post, i) => <PostCard post={post} index={i} />)}
      </div>

      <aside class="blog-sidebar">
        <div class="sidebar-block">
          <div class="sidebar-heading">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
            Trending now
          </div>
          <ul class="trending-list">
            {trending.map((post, i) => (
              <li>
                <a href={`${import.meta.env.BASE_URL}/${post.id}/`} class="trending-item">
                  <span class="trending-num">{i + 1}</span>
                  <div class="trending-content">
                    <div class="trending-cat">{post.data.tags[0] || 'Article'}</div>
                    <div class="trending-title">{post.data.title}</div>
                    <div class="trending-time">{readingTime(post)} min read</div>
                  </div>
                </a>
              </li>
            ))}
          </ul>
        </div>
      </aside>
    </div>

    <nav class="blog-pagination">
      {page.url.prev && (
        <a href={page.currentPage === 2 ? import.meta.env.BASE_URL : page.url.prev} class="blog-pagination-link">
          &larr; Newer posts
        </a>
      )}
      {page.url.next && (
        <a href={page.url.next} class="blog-pagination-link">
          Older posts &rarr;
        </a>
      )}
    </nav>
  </div>

  <Footer slot="footer" />
</BaseLayout>

<style>
  .page-header {
    background: linear-gradient(135deg, #2d1b69 0%, #4F378B 60%, #7c3aed 100%);
    padding: 60px 40px 40px;
    text-align: center;
  }
  .page-header-inner { max-width: 600px; margin: 0 auto; }
  .page-header-label {
    font-family: var(--font-display, 'Urbanist', sans-serif);
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255,255,255,.7);
    margin-bottom: 12px;
  }
  .page-header h1 {
    font-family: var(--font-display, 'Urbanist', sans-serif);
    font-size: clamp(22px, 3vw, 36px);
    font-weight: 900;
    color: #fff;
    line-height: 1.2;
    letter-spacing: -0.02em;
    margin: 0 0 8px;
  }
  .page-header p { font-size: 14px; color: rgba(255,255,255,.7); margin: 0; }

  .blog-outer { max-width: 1200px; margin: 0 auto; padding: 48px 32px 80px; }

  .blog-body {
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: 40px;
    align-items: start;
  }
  .blog-cards { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }

  .blog-sidebar { position: sticky; top: 88px; }
  .sidebar-block {
    background: var(--color-bg-surface);
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(15,23,42,.06);
  }
  .sidebar-heading {
    font-family: var(--font-display, 'Urbanist', sans-serif);
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255,255,255,.9);
    background: #0f172a;
    padding: 14px 20px;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .sidebar-heading svg { width: 14px; height: 14px; color: var(--color-primary); }
  .trending-list { list-style: none; margin: 0; padding: 0; }
  .trending-item {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    padding: 14px 20px;
    text-decoration: none;
    color: inherit;
    border-bottom: 1px solid var(--color-border);
    transition: background .15s;
  }
  .trending-item:last-child { border-bottom: none; }
  .trending-item:hover { background: var(--color-bg); }
  .trending-num {
    font-family: var(--font-display, 'Urbanist', sans-serif);
    font-size: 22px;
    font-weight: 900;
    color: var(--color-border);
    line-height: 1;
    flex-shrink: 0;
    width: 24px;
    text-align: right;
  }
  .trending-content { flex: 1; min-width: 0; }
  .trending-cat {
    font-family: var(--font-display, 'Urbanist', sans-serif);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-primary);
    margin-bottom: 4px;
  }
  .trending-title {
    font-family: var(--font-display, 'Urbanist', sans-serif);
    font-size: 13px;
    font-weight: 700;
    line-height: 1.4;
    color: var(--color-text);
    margin-bottom: 4px;
  }
  .trending-time { font-size: 11px; color: #9ca3af; }

  .blog-pagination { margin-top: 48px; display: flex; gap: 16px; justify-content: center; }
  .blog-pagination-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-display, 'Urbanist', sans-serif);
    font-size: 14px;
    font-weight: 700;
    color: var(--color-primary);
    text-decoration: none;
    padding: 10px 24px;
    border: 2px solid var(--color-primary);
    border-radius: 999px;
    transition: background .15s, color .15s;
  }
  .blog-pagination-link:hover { background: var(--color-primary); color: var(--color-on-primary); }

  @media (max-width: 1024px) {
    .blog-outer { padding: 40px 24px 64px; }
    .blog-body { grid-template-columns: 1fr; gap: 32px; }
    .blog-sidebar { position: static; }
  }
  @media (max-width: 768px) {
    .blog-cards { grid-template-columns: 1fr; }
    .page-header { padding: 48px 24px 32px; }
  }
  @media (max-width: 480px) { .blog-outer { padding: 28px 16px 48px; } }
</style>
