---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PostCard from '../components/PostCard.astro';

const PAGE_SIZE = 10;

const posts = await getCollection('blog', ({ data }) => !data.draft);
const sorted = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const page1 = sorted.slice(0, PAGE_SIZE);
const hasMore = sorted.length > PAGE_SIZE;
---

<BaseLayout title="Blog" description="Dating tips, success stories, and guides for Latin singles.">
  <Header slot="header" />

  <h1 class="page-title">LatinFlare Blog</h1>
  <p class="page-desc">Dating tips, success stories, and guides for Latin singles.</p>

  <div class="post-grid">
    {page1.map((post) => <PostCard post={post} />)}
  </div>

  {hasMore && (
    <nav class="pagination">
      <a href="/page/2/">Older posts &rarr;</a>
    </nav>
  )}

  <Footer slot="footer" />
</BaseLayout>

<style>
  .page-title { font-size: 2rem; font-weight: 800; margin-bottom: 0.5rem; }
  .page-desc { color: var(--color-muted); margin-bottom: 2rem; }
  .post-grid { display: grid; gap: 1.5rem; }
  .pagination { margin-top: 2.5rem; text-align: right; }
</style>
