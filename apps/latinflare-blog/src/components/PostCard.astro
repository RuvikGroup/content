---
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
  index?: number;
}

const { post, index = 0 } = Astro.props;
const { title, description, pubDate, author, tags, heroImage, flag, location } = post.data;

const formattedDate = pubDate.toLocaleDateString('en-US', {
  timeZone: 'UTC',
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const readingTime = Math.max(1, Math.round((post.body ?? '').split(/\s+/).length / 200));

const GRADIENTS = [
  'linear-gradient(145deg, #2e1065 0%, #7c3aed 100%)',
  'linear-gradient(145deg, #1e1b4b 0%, #4338ca 100%)',
  'linear-gradient(145deg, #4a1d96 0%, #a855f7 100%)',
  'linear-gradient(145deg, #701a75 0%, #c026d3 100%)',
  'linear-gradient(145deg, #0f4c81 0%, #0ea5e9 100%)',
  'linear-gradient(145deg, #881337 0%, #e11d48 100%)',
];
const gradient = GRADIENTS[index % GRADIENTS.length];

const topicAbbr = location?.slice(0, 2).toUpperCase() || (tags[0] || title).slice(0, 2).toUpperCase();
const topicLabel = tags[0] || 'Article';
---

<a href={`/${post.id}/`} class="blog-card">
  <div class="blog-card-header" style={`background: ${gradient}`}>
    <div class="blog-card-header-bg">{topicAbbr}</div>
    {flag && <div class="blog-card-flag">{flag}</div>}
    <div class="blog-card-topic-sub">{location || 'Article'}</div>
    <div class="blog-card-topic">{topicLabel}</div>
  </div>
  <div class="blog-card-body">
    <h3 class="blog-card-title">{title}</h3>
    <p class="blog-card-excerpt">{description}</p>
    <div class="blog-meta">
      <span>{author}</span>
      <span class="blog-meta-dot"></span>
      <time datetime={pubDate.toISOString()}>{formattedDate}</time>
      <span class="blog-meta-dot"></span>
      <span>~{readingTime} min</span>
    </div>
    <span class="read-more">Read more <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg></span>
  </div>
</a>

<style>
  .blog-card {
    background: var(--color-bg-surface);
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(15,23,42,.06);
    text-decoration: none;
    color: inherit;
    transition: transform .2s, box-shadow .2s;
    display: flex;
    flex-direction: column;
  }
  .blog-card:hover { transform: translateY(-3px); box-shadow: 0 12px 32px rgba(15,23,42,.1); }

  .blog-card-header {
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 12px 16px 14px;
    min-height: 88px;
    position: relative;
    overflow: hidden;
  }
  .blog-card-header-bg {
    position: absolute;
    top: -6px; right: -6px;
    font-family: var(--font-display, 'Urbanist', sans-serif);
    font-weight: 900;
    font-size: 52px;
    color: rgba(255,255,255,.08);
    line-height: 1;
    letter-spacing: -0.04em;
    user-select: none;
    pointer-events: none;
  }
  .blog-card-flag {
    position: absolute;
    top: 8px;
    left: 14px;
    font-size: 24px;
    line-height: 1;
    opacity: 0.6;
    z-index: 1;
    user-select: none;
    pointer-events: none;
  }
  .blog-card-topic {
    font-family: var(--font-display, 'Urbanist', sans-serif);
    font-size: 18px;
    font-weight: 900;
    color: #fff;
    letter-spacing: -0.02em;
    line-height: 1;
    position: relative;
  }
  .blog-card-topic-sub {
    font-family: var(--font-display, 'Urbanist', sans-serif);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255,255,255,.55);
    margin-bottom: 5px;
    position: relative;
  }
  .blog-card-body { padding: 20px 22px 22px; flex: 1; display: flex; flex-direction: column; }
  .blog-card-title {
    font-family: var(--font-display, 'Urbanist', sans-serif);
    font-size: 16px;
    font-weight: 700;
    line-height: 1.35;
    color: var(--color-text);
    margin-bottom: 10px;
    letter-spacing: -0.01em;
  }
  .blog-card-excerpt {
    font-size: 13px;
    line-height: 1.65;
    color: var(--color-muted);
    flex: 1;
    margin-bottom: 12px;
  }
  .blog-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 12px;
    color: var(--color-muted);
    margin-bottom: 14px;
    flex-wrap: wrap;
  }
  .blog-meta-dot { width: 3px; height: 3px; border-radius: 50%; background: var(--color-border); flex-shrink: 0; }
  .read-more {
    font-family: var(--font-display, 'Urbanist', sans-serif);
    font-size: 13px;
    font-weight: 700;
    color: var(--color-primary);
    display: flex;
    align-items: center;
    gap: 4px;
    margin-top: auto;
    text-decoration: none;
  }
  .read-more svg { width: 14px; height: 14px; transition: transform .15s; }
  .blog-card:hover .read-more svg { transform: translateX(3px); }
</style>
