---
interface Props {
  author: string;
  rating: number;
  date?: string;
  platform?: 'ios' | 'android' | 'web';
  verified?: boolean;
}

const { author, rating, date, platform, verified = false } = Astro.props;

if (!author || !String(author).trim()) {
  throw new Error('ReviewCard: required prop "author" must be a non-empty string.');
}

const numericRating = Number(rating);
if (isNaN(numericRating)) {
  throw new Error(
    `ReviewCard: prop "rating" must be a number, got "${rating}". Use JSX syntax: rating={4.5} not rating="4.5".`
  );
}

const clampedRating = Math.min(5, Math.max(0, numericRating));
const fullStars = Math.floor(clampedRating);
const hasHalf = clampedRating % 1 >= 0.5;

// Random suffix so gradient IDs never collide when multiple ReviewCards appear on one page.
const uid = Math.random().toString(36).slice(2, 9);
---

<div class="review-card">
  <div class="review-header">
    <div class="review-avatar">{String(author).slice(0, 2).toUpperCase()}</div>
    <div class="review-meta">
      <div class="review-author">
        {author}
        {verified && <span class="review-verified">✓ Verified</span>}
      </div>
      <div class="review-stars">
        {Array.from({ length: 5 }, (_, i) => {
          const isFull = i < fullStars;
          const isHalf = !isFull && i === fullStars && hasHalf;
          const gradId = `half-${i}-${uid}`;
          return (
            <svg class={`star ${isFull ? 'star--full' : isHalf ? 'star--half' : 'star--empty'}`} viewBox="0 0 24 24">
              {isHalf && (
                <defs>
                  <linearGradient id={gradId} x1="0" x2="1" y1="0" y2="0">
                    <stop offset="50%" stop-color="currentColor"/>
                    <stop offset="50%" stop-color="transparent"/>
                  </linearGradient>
                </defs>
              )}
              <polygon
                points="12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26"
                fill={isFull ? 'currentColor' : isHalf ? `url(#${gradId})` : 'none'}
                stroke="currentColor"
                stroke-width="1.5"
              />
            </svg>
          );
        })}
        <span class="review-rating-num">{clampedRating.toFixed(1)}</span>
      </div>
    </div>
    {date && <span class="review-date">{date}</span>}
  </div>
  <div class="review-body">
    <slot />
  </div>
  {platform && (
    <div class="review-platform">
      via {platform === 'ios' ? 'App Store' : platform === 'android' ? 'Google Play' : 'Web'}
    </div>
  )}
</div>

<style>
  .review-card {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 16px;
    padding: 20px 24px;
    margin: 24px 0;
  }
  .review-header {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    margin-bottom: 14px;
  }
  .review-avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--color-primary), #c2185b);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display, 'Urbanist', sans-serif);
    font-size: 14px;
    font-weight: 800;
    color: #fff;
    flex-shrink: 0;
  }
  .review-meta { flex: 1; min-width: 0; }
  .review-author {
    font-family: var(--font-display, 'Urbanist', sans-serif);
    font-size: 15px;
    font-weight: 700;
    color: var(--color-text);
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
    margin-bottom: 6px;
  }
  .review-verified {
    font-size: 11px;
    font-weight: 600;
    color: #059669;
    background: rgba(16, 185, 129, 0.1);
    padding: 2px 7px;
    border-radius: 999px;
  }
  .review-stars {
    display: flex;
    align-items: center;
    gap: 3px;
  }
  .star {
    width: 16px;
    height: 16px;
    color: var(--color-primary);
  }
  .star--empty { color: #d1d5db; }
  .review-rating-num {
    font-family: var(--font-display, 'Urbanist', sans-serif);
    font-size: 13px;
    font-weight: 700;
    color: var(--color-muted);
    margin-left: 4px;
  }
  .review-date {
    font-size: 12px;
    color: var(--color-muted);
    white-space: nowrap;
    flex-shrink: 0;
  }
  .review-body :global(p) {
    font-size: 15px !important;
    line-height: 1.7 !important;
    color: var(--color-text) !important;
    margin-bottom: 0 !important;
  }
  .review-platform {
    margin-top: 12px;
    font-size: 12px;
    color: var(--color-muted);
    font-style: italic;
  }
</style>
