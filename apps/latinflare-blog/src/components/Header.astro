---
import ThemeToggle from './ThemeToggle.astro';
---

<header>
  <nav>
    <a href={import.meta.env.BASE_URL} class="logo-text-fallback" aria-label="LatinFlare Blog">
      <span class="lf-icon">🔥</span> LatinFlare
    </a>
    <div class="nav-right">
      <ul>
        <li><a href={import.meta.env.BASE_URL}>Home</a></li>
        <li><a href={`${import.meta.env.BASE_URL}/tags/`}>Tags</a></li>
        <li><a href={`${import.meta.env.BASE_URL}/rss.xml`}>RSS</a></li>
      </ul>
      <ThemeToggle />
    </div>
  </nav>
</header>

<style>
  header {
    border-bottom: 1px solid var(--color-border);
    background: var(--color-bg-surface);
    position: sticky;
    top: 0;
    z-index: 10;
    transition: background-color 0.2s ease, border-color 0.2s ease;
  }
  nav {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0.875rem 1rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }
  .logo-text-fallback {
    font-size: 1.1rem;
    font-weight: 800;
    color: var(--color-primary);
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 0.3rem;
    flex-shrink: 0;
  }
  .logo-text-fallback:hover { text-decoration: none; opacity: 0.85; }
  .lf-icon { font-size: 1.2rem; }
  .nav-right { display: flex; align-items: center; gap: 1.5rem; }
  ul {
    list-style: none;
    display: flex;
    gap: 1.5rem;
  }
  ul a {
    color: var(--color-text);
    font-size: 0.9rem;
    font-weight: 500;
  }
  ul a:hover { color: var(--color-primary); }
</style>
