---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, pubDate, updatedDate, author, tags, heroImage, flag, location } = post.data;

const dateOpts: Intl.DateTimeFormatOptions = {
  timeZone: 'UTC',
  year: 'numeric',
  month: 'long',
  day: 'numeric',
};
const formattedPubDate = pubDate.toLocaleDateString('en-US', dateOpts);
const formattedUpdatedDate = updatedDate?.toLocaleDateString('en-US', dateOpts);
const readingTime = Math.max(1, Math.round((post.body ?? '').split(/\s+/).length / 200));

const pageUrl = encodeURIComponent(new URL(Astro.url.pathname, Astro.site).href);
const pageTitle = encodeURIComponent(title);
const ogImage = heroImage && Astro.site
  ? new URL(heroImage, Astro.site).href
  : heroImage;

const topicAbbr = location?.slice(0, 3).toUpperCase() || (tags[0] || title).slice(0, 3).toUpperCase();
---

<BaseLayout title={title} description={description} image={ogImage} fullWidth>
  <Header slot="header" />

  <div class="reading-progress" id="reading-progress"></div>

  <div class="sticky-bar" id="sticky-bar">
    <a href={import.meta.env.BASE_URL} class="sticky-bar-back">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
      Blog
    </a>
    <div class="sticky-bar-sep"></div>
    <span class="sticky-bar-title">{title}</span>
    <span class="sticky-bar-time" id="sticky-time">{readingTime} min left</span>
  </div>

  <div class="article-hero">
    <a href={import.meta.env.BASE_URL} class="article-back-link">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
      Blog
    </a>
    <div class="article-hero-badges">
      {tags.length > 0 && <span class="article-meta-cat">{tags[0]}</span>}
      {flag && <span class="article-meta-flag">{flag}</span>}
      {location && <span class="article-meta-location">{location}</span>}
    </div>
    <h1>{title}</h1>
    <div class="article-hero-meta">
      <div class="author-avatar">{author.slice(0, 2).toUpperCase()}</div>
      <strong>{author}</strong>
      <span class="article-hero-meta-dot"></span>
      <time datetime={pubDate.toISOString()}>{formattedPubDate}</time>
      {updatedDate && <><span class="article-hero-meta-dot"></span><span>Updated {formattedUpdatedDate}</span></>}
      <span class="article-hero-meta-dot"></span>
      <span>{readingTime} min read</span>
    </div>
  </div>

  {heroImage && (
    <div class="article-hero-img">
      <div class="article-hero-media">
        <img src={heroImage} alt={title} />
        {flag && <div class="article-hero-flag">{flag}</div>}
        <div class="article-hero-img-text">{topicAbbr}</div>
      </div>
    </div>
  )}
  {!heroImage && (
    <div class="article-hero-img">
      <div class="article-hero-media article-hero-media--no-img">
        {flag && <div class="article-hero-flag">{flag}</div>}
        <div class="article-hero-img-text">{topicAbbr}</div>
      </div>
    </div>
  )}

  <article id="article-body">
    <div class="article-wrap">
      <div class="prose">
        <slot />
      </div>

      {tags.length > 0 && (
        <div class="article-tags">
          <span class="article-tag-label">Tags</span>
          {tags.map((tag) => (
            <a href={`/tags/${tag}/`} class="article-tag">#{tag}</a>
          ))}
        </div>
      )}

      <div class="article-author-bio">
        <div class="author-bio-avatar">{author.slice(0, 2).toUpperCase()}</div>
        <div>
          <div class="author-bio-name">{author}</div>
          <div class="author-bio-role">Editorial</div>
          <div class="author-bio-text">The LatinFlare editorial team covers dating culture, travel, and real stories from across Latin America.</div>
        </div>
      </div>

      <div class="share-links">
        <span>Share:</span>
        <a href={`https://twitter.com/intent/tweet?url=${pageUrl}&text=${pageTitle}`} target="_blank" rel="noopener noreferrer">Twitter/X</a>
        <a href={`https://www.facebook.com/sharer/sharer.php?u=${pageUrl}`} target="_blank" rel="noopener noreferrer">Facebook</a>
        <a href={`https://www.linkedin.com/shareArticle?mini=true&url=${pageUrl}&title=${pageTitle}`} target="_blank" rel="noopener noreferrer">LinkedIn</a>
      </div>
    </div>
  </article>

  <Footer slot="footer" />
</BaseLayout>

<style>
  .reading-progress {
    position: fixed;
    top: 0; left: 0;
    height: 3px;
    background: var(--color-primary);
    width: 0%;
    z-index: 200;
    transition: width .1s linear;
  }

  .sticky-bar {
    position: fixed;
    top: 60px; left: 0; right: 0;
    z-index: 90;
    background: rgba(255,255,255,.92);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-bottom: 1px solid rgba(229,231,235,.8);
    height: 46px;
    display: flex;
    align-items: center;
    padding: 0 40px;
    gap: 16px;
    transform: translateY(-100%);
    transition: transform 0.3s ease;
    pointer-events: none;
  }
  [data-theme='dark'] .sticky-bar {
    background: rgba(28,26,32,.92);
    border-color: rgba(61,58,71,.8);
  }
  .sticky-bar.visible { transform: translateY(0); pointer-events: auto; }
  .sticky-bar-back {
    display: flex;
    align-items: center;
    gap: 5px;
    font-family: var(--font-display, 'Urbanist', sans-serif);
    font-size: 12px;
    font-weight: 600;
    color: #9ca3af;
    text-decoration: none;
    flex-shrink: 0;
    transition: color .15s;
  }
  .sticky-bar-back:hover { color: var(--color-primary); }
  .sticky-bar-back svg { width: 13px; height: 13px; }
  .sticky-bar-sep { width: 1px; height: 16px; background: var(--color-border); flex-shrink: 0; }
  .sticky-bar-title {
    font-family: var(--font-display, 'Urbanist', sans-serif);
    font-size: 13px;
    font-weight: 700;
    color: var(--color-text);
    flex: 1;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    letter-spacing: -0.01em;
  }
  .sticky-bar-time {
    font-family: var(--font-display, 'Urbanist', sans-serif);
    font-size: 12px;
    color: #9ca3af;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .article-hero {
    padding: 80px 40px 0;
    max-width: 760px;
    margin: 0 auto;
    text-align: center;
  }
  .article-back-link {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-family: var(--font-display, 'Urbanist', sans-serif);
    font-size: 13px;
    font-weight: 600;
    color: #9ca3af;
    text-decoration: none;
    margin-bottom: 18px;
    transition: color .15s;
  }
  .article-back-link:hover { color: var(--color-primary); }
  .article-back-link svg { width: 13px; height: 13px; }
  .article-hero-badges { margin-bottom: 16px; display: flex; justify-content: center; align-items: center; gap: 8px; flex-wrap: wrap; }
  .article-meta-flag {
    font-size: 20px;
    line-height: 1;
  }
  .article-meta-location {
    font-family: var(--font-display, 'Urbanist', sans-serif);
    font-size: 12px;
    font-weight: 700;
    color: var(--color-muted);
    letter-spacing: 0.04em;
  }
  .article-meta-cat {
    background: rgba(79,55,139,.08);
    color: var(--color-primary);
    padding: 3px 10px;
    border-radius: 999px;
    font-family: var(--font-display, 'Urbanist', sans-serif);
    font-size: 12px;
    font-weight: 700;
  }
  .article-hero h1 {
    font-family: var(--font-display, 'Urbanist', sans-serif);
    font-size: clamp(28px, 4.5vw, 50px);
    font-weight: 900;
    line-height: 1.1;
    letter-spacing: -0.025em;
    color: var(--color-text);
    margin-bottom: 24px;
  }
  .article-hero-meta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    font-size: 14px;
    color: #9ca3af;
    flex-wrap: wrap;
    padding-bottom: 40px;
  }
  .article-hero-meta-dot { width: 3px; height: 3px; border-radius: 50%; background: #d1d5db; flex-shrink: 0; }
  .author-avatar {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--color-primary), #7c3aed);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display, 'Urbanist', sans-serif);
    font-weight: 800;
    font-size: 12px;
    color: #fff;
    flex-shrink: 0;
  }
  .article-hero-meta strong { color: var(--color-text); font-weight: 600; }

  .article-hero-img {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 40px 56px;
  }
  .article-hero-media {
    border-radius: 20px;
    overflow: hidden;
    aspect-ratio: 21/9;
    background: linear-gradient(135deg, #1a0845 0%, #4F378B 50%, #7c3aed 100%);
    position: relative;
    display: flex;
    align-items: flex-end;
  }
  .article-hero-media img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.35;
  }
  .article-hero-media--no-img { aspect-ratio: 21/6; }
  .article-hero-flag {
    position: absolute;
    top: 20px;
    right: 28px;
    font-size: clamp(48px, 8vw, 96px);
    line-height: 1;
    opacity: 0.25;
    user-select: none;
    pointer-events: none;
    z-index: 1;
  }
  .article-hero-img-text {
    position: relative;
    font-family: var(--font-display, 'Urbanist', sans-serif);
    font-size: clamp(60px, 12vw, 160px);
    font-weight: 900;
    color: rgba(255,255,255,.1);
    line-height: 0.85;
    letter-spacing: -0.05em;
    padding: 0 40px 20px;
    user-select: none;
    white-space: nowrap;
    overflow: hidden;
  }

  article { padding: 0 0 80px; }
  .article-wrap { max-width: 720px; margin: 0 auto; padding: 0 40px; }

  .prose :global(p) { font-size: 18px; line-height: 1.85; color: var(--color-text); margin-bottom: 28px; }
  .prose :global(p:last-child) { margin-bottom: 0; }
  .prose :global(strong) { color: var(--color-text); font-weight: 700; }
  .prose :global(a) { color: var(--color-primary); text-decoration: underline; text-underline-offset: 3px; }
  .prose :global(a:hover) { opacity: 0.8; }

  .prose :global(h2) {
    font-family: var(--font-display, 'Urbanist', sans-serif);
    font-size: clamp(22px, 3vw, 30px);
    font-weight: 800;
    color: var(--color-text);
    letter-spacing: -0.02em;
    line-height: 1.2;
    margin: 52px 0 18px;
  }
  .prose :global(h3) {
    font-family: var(--font-display, 'Urbanist', sans-serif);
    font-size: clamp(18px, 2.5vw, 22px);
    font-weight: 700;
    color: var(--color-text);
    letter-spacing: -0.015em;
    line-height: 1.3;
    margin: 40px 0 14px;
  }
  .prose :global(ul), .prose :global(ol) { margin: 0 0 28px 0; padding-left: 0; list-style: none; }
  .prose :global(ul li), .prose :global(ol li) {
    font-size: 17px;
    line-height: 1.75;
    color: var(--color-text);
    margin-bottom: 10px;
    padding-left: 24px;
    position: relative;
  }
  .prose :global(ul li::before) {
    content: '';
    position: absolute;
    left: 0; top: 12px;
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--color-primary);
  }
  .prose :global(ol) { counter-reset: ol-counter; }
  .prose :global(ol li) { counter-increment: ol-counter; }
  .prose :global(ol li::before) {
    content: counter(ol-counter);
    position: absolute;
    left: 0; top: 1px;
    font-family: var(--font-display, 'Urbanist', sans-serif);
    font-size: 14px;
    font-weight: 800;
    color: var(--color-primary);
    line-height: 1.75;
  }
  .prose :global(hr) { border: none; border-top: 1px solid var(--color-border); margin: 48px 0; }
  .prose :global(blockquote) { border-left: 3px solid var(--color-primary); padding: 4px 0 4px 24px; margin: 40px 0; }
  .prose :global(blockquote p) {
    font-family: var(--font-display, 'Urbanist', sans-serif) !important;
    font-size: 20px !important;
    font-weight: 700 !important;
    color: var(--color-text) !important;
    line-height: 1.45 !important;
    font-style: italic;
  }
  .prose :global(code) { background: var(--color-code-bg); padding: 0.15rem 0.3rem; border-radius: 4px; font-size: 0.9em; }
  .prose :global(pre) { background: #1e1e2e; color: #cdd6f4; padding: 1.25rem; border-radius: 12px; overflow-x: auto; margin-bottom: 1.5rem; }
  .prose :global(pre code) { background: none; padding: 0; border-radius: 0; font-size: 0.9em; }
  .prose :global(img) { max-width: 100%; height: auto; border-radius: 12px; margin: 1.5rem 0; }
  .prose :global(table) { width: 100%; border-collapse: collapse; margin: 1.5rem 0; font-size: 0.95rem; }
  .prose :global(th) { text-align: left; font-family: var(--font-display, 'Urbanist', sans-serif); font-weight: 700; padding: 0.65rem 0.75rem; border-bottom: 2px solid var(--color-primary); background: #f9fafb; }
  .prose :global(td) { padding: 0.55rem 0.75rem; border-bottom: 1px solid var(--color-border); }
  .prose :global(tr:last-child td) { border-bottom: none; }

  .article-tags {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
    padding: 32px 0;
    border-top: 1px solid var(--color-border);
    margin-top: 40px;
  }
  .article-tag-label {
    font-family: var(--font-display, 'Urbanist', sans-serif);
    font-size: 12px;
    font-weight: 700;
    color: #9ca3af;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .article-tag {
    font-family: var(--font-display, 'Urbanist', sans-serif);
    font-size: 13px;
    font-weight: 600;
    color: var(--color-muted);
    background: var(--color-border);
    padding: 5px 12px;
    border-radius: 999px;
    text-decoration: none;
    transition: background .15s, color .15s;
  }
  .article-tag:hover { background: var(--color-tag-bg); color: var(--color-tag-text); }

  .article-author-bio {
    display: flex;
    gap: 20px;
    align-items: flex-start;
    background: var(--color-bg);
    border-radius: 20px;
    padding: 28px;
    margin-top: 16px;
  }
  .author-bio-avatar {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--color-primary), #7c3aed);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display, 'Urbanist', sans-serif);
    font-size: 20px;
    font-weight: 900;
    color: #fff;
    flex-shrink: 0;
  }
  .author-bio-name { font-family: var(--font-display, 'Urbanist', sans-serif); font-size: 16px; font-weight: 800; color: var(--color-text); margin-bottom: 2px; }
  .author-bio-role { font-size: 13px; color: #9ca3af; margin-bottom: 8px; }
  .author-bio-text { font-size: 14px; line-height: 1.65; color: var(--color-muted); }

  .share-links {
    margin-top: 2.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border);
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    font-size: 0.9rem;
  }
  .share-links span { color: var(--color-muted); font-weight: 600; }
  .share-links a {
    color: var(--color-on-primary);
    background: var(--color-primary);
    padding: 0.35rem 0.85rem;
    border-radius: 9999px;
    font-weight: 500;
    text-decoration: none;
    transition: opacity 0.15s;
  }
  .share-links a:hover { opacity: 0.85; text-decoration: none; }

  @media (max-width: 900px) {
    .article-hero { padding: 80px 24px 0; }
    .article-hero-img { padding: 0 24px 40px; }
    .article-wrap { padding: 0 24px; }
    .sticky-bar { padding: 0 24px; }
  }
  @media (max-width: 640px) {
    .article-hero h1 { font-size: 26px; }
    .prose :global(p) { font-size: 16px; }
    .article-hero-media { aspect-ratio: 16/7; }
    .article-hero-img { padding: 0 16px 32px; }
    .article-wrap { padding: 0 20px; }
    .sticky-bar { padding: 0 16px; }
    .article-author-bio { flex-direction: column; }
  }
</style>

<script define:vars={{ readingTime }}>
const progressBar = document.getElementById('reading-progress');
const stickyBar = document.getElementById('sticky-bar');
const stickyTime = document.getElementById('sticky-time');
const heroEl = document.querySelector('.article-hero');
const articleEl = document.getElementById('article-body');
const totalMinutes = readingTime;

window.addEventListener('scroll', () => {
  const sy = window.scrollY;

  if (articleEl && progressBar) {
    const top = articleEl.getBoundingClientRect().top + sy;
    const scrollable = Math.max(articleEl.offsetHeight - window.innerHeight, 1);
    const pct = Math.min(Math.max((sy - top) / scrollable, 0), 1);
    progressBar.style.width = (pct * 100) + '%';
    if (stickyTime) {
      const remaining = Math.ceil(totalMinutes * (1 - pct));
      stickyTime.textContent = remaining <= 0 ? 'Done' : remaining + ' min left';
    }
  }

  if (heroEl && stickyBar) {
    const heroBottom = heroEl.getBoundingClientRect().bottom;
    stickyBar.classList.toggle('visible', heroBottom < 0);
  }
}, { passive: true });
</script>
