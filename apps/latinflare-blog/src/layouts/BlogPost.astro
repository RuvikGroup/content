---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, pubDate, updatedDate, author, tags, heroImage } = post.data;

const dateOpts: Intl.DateTimeFormatOptions = {
  timeZone: 'UTC',
  year: 'numeric',
  month: 'long',
  day: 'numeric',
};
const formattedPubDate = pubDate.toLocaleDateString('en-US', dateOpts);
const formattedUpdatedDate = updatedDate?.toLocaleDateString('en-US', dateOpts);

const pageUrl = encodeURIComponent(new URL(Astro.url.pathname, Astro.site).href);
const pageTitle = encodeURIComponent(title);
---

<BaseLayout title={title} description={description} image={heroImage}>
  <Header slot="header" />
  <article>
    {heroImage && (
      <img
        src={heroImage}
        alt={title}
        class="hero-image"
        onerror="this.style.display='none'"
      />
    )}
    <header class="post-header">
      <h1>{title}</h1>
      <p class="meta">
        By {author} &middot; <time datetime={pubDate.toISOString()}>{formattedPubDate}</time>
        {updatedDate && (
          <span> &middot; Updated <time datetime={updatedDate.toISOString()}>{formattedUpdatedDate}</time></span>
        )}
      </p>
      {tags.length > 0 && (
        <div class="tag-list">
          {tags.map((tag) => (
            <a
              href={`/tags/${tag}/`}
              class="tag-pill"
              aria-label={`View posts tagged ${tag}`}
            >
              #{tag}
            </a>
          ))}
        </div>
      )}
    </header>
    <div class="prose">
      <slot />
    </div>
    <div class="share-links">
      <span>Share:</span>
      <a
        href={`https://twitter.com/intent/tweet?url=${pageUrl}&text=${pageTitle}`}
        target="_blank"
        rel="noopener noreferrer"
      >Twitter/X</a>
      <a
        href={`https://www.facebook.com/sharer/sharer.php?u=${pageUrl}`}
        target="_blank"
        rel="noopener noreferrer"
      >Facebook</a>
      <a
        href={`https://www.linkedin.com/shareArticle?mini=true&url=${pageUrl}&title=${pageTitle}`}
        target="_blank"
        rel="noopener noreferrer"
      >LinkedIn</a>
    </div>
  </article>
  <Footer slot="footer" />
</BaseLayout>

<style>
  .hero-image { width: 100%; border-radius: 8px; margin-bottom: 1.5rem; }

  .post-header { margin-bottom: 2rem; }
  .post-header h1 { font-size: 2rem; font-weight: 800; line-height: 1.2; margin-bottom: 0.75rem; }
  .meta { color: var(--color-muted); font-size: 0.875rem; }

  .tag-list { margin-top: 0.75rem; display: flex; flex-wrap: wrap; gap: 0.4rem; }
  .tag-pill {
    font-size: 0.8rem;
    background: #e8def8;
    color: #4F378B;
    padding: 0.2rem 0.6rem;
    border-radius: 9999px;
    text-decoration: none;
  }
  .tag-pill:hover { background: #d0bcfe; }

  .prose { line-height: 1.7; font-size: 1.05rem; }
  .prose :global(h2) { font-size: 1.5rem; font-weight: 700; margin: 2rem 0 0.75rem; }
  .prose :global(h3) { font-size: 1.2rem; font-weight: 600; margin: 1.5rem 0 0.5rem; }
  .prose :global(p) { margin-bottom: 1rem; }
  .prose :global(ul), .prose :global(ol) { margin: 0 0 1rem 1.5rem; }
  .prose :global(li) { margin-bottom: 0.25rem; }
  .prose :global(strong) { font-weight: 700; }
  .prose :global(code) { background: #f3f4f6; padding: 0.15rem 0.3rem; border-radius: 3px; font-size: 0.9em; }
  .prose :global(pre) { background: #1e1e2e; color: #cdd6f4; padding: 1rem; border-radius: 8px; overflow-x: auto; margin-bottom: 1rem; }

  .share-links {
    margin-top: 2.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border);
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    font-size: 0.9rem;
  }
  .share-links span { color: var(--color-muted); font-weight: 600; }
  .share-links a {
    color: #fff;
    background: var(--color-primary);
    padding: 0.35rem 0.85rem;
    border-radius: 9999px;
    font-weight: 500;
    text-decoration: none;
    transition: opacity 0.15s;
  }
  .share-links a:hover { opacity: 0.85; text-decoration: none; }
</style>
